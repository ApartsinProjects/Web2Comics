# Telegram bot
TELEGRAM_BOT_TOKEN=

# Optional: comma-separated allowlist of chat IDs
# COMICBOT_ALLOWED_CHAT_IDS=123456789,987654321

# Optional: custom engine config path
# COMICBOT_ENGINE_CONFIG=comicbot/config/default.bot.yml

# Optional runtime tuning
# COMICBOT_OUT_DIR=comicbot/out
# COMICBOT_POLL_TIMEOUT_SEC=25
# COMICBOT_POLL_INTERVAL_MS=1200
# COMICBOT_FETCH_TIMEOUT_MS=45000
# COMICBOT_TITLE_PREFIX=Telegram Comic
# COMICBOT_DEBUG_ARTIFACTS=false

# Provider keys (at least one matching your default.bot.yml)
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# HUGGINGFACE_INFERENCE_API_TOKEN=
